# System Configuration
PORT=5000
NODE_ENV=development
CLIENT_URL=http://localhost:5173

# Database Configuration
MONGODB_URI=mongodb://127.0.0.1:27017/dsa_visualizer

# Redis Configuration (Used for BullMQ)
REDIS_URL=redis://127.0.0.1:6379

# Cookie Security
COOKIE_SECRET=replace_with_a_secure_cookie_secret_at_least_32_chars_long

# PASETO Authentication Keys (Ed25519 PEM strings, escape newlines with \n or wrap in quotes)
# Access Token Keys (Ed25519)
PASETO_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----"
PASETO_PUBLIC_KEY="-----BEGIN PUBLIC KEY-----\n...\n-----END PUBLIC KEY-----"

# Refresh Token Keys (Ed25519)
REFRESH_TOKEN_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----"
REFRESH_TOKEN_PUBLIC_KEY="-----BEGIN PUBLIC KEY-----\n...\n-----END PUBLIC KEY-----"

# Cloudinary Storage Configuration
CLOUDINARY_CLOUD_NAME=your_cloudinary_cloud_name
CLOUDINARY_API_KEY=your_cloudinary_api_key
CLOUDINARY_API_SECRET=your_cloudinary_api_secret

# Email Configuration (Nodemailer / SMTP)
EMAIL_HOST=smtp.mailtrap.io
EMAIL_PORT=2525
EMAIL_USER=your_smtp_username
EMAIL_PASS=your_smtp_password
EMAIL_FROM=noreply@algoviz.pro

# External API Configuration
GROQ_API_KEY=your_groq_api_key
